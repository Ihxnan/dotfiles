{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
    "logo": {
        "width": 25,
        "color": {
            "1": "{{colors.primary.default.hex}}",
            "2": "{{colors.primary.default.hex}}"
        },
        "padding": {
            "top": 1,
            "left": 2,
            "right": 2
        }
    },
    "display": {
        "separator": " ",
        "color": {
            "title": "{{colors.on_surface_variant.default.hex}}",
            "output": "{{colors.on_surface_variant.default.hex}}"
        }
    },
    "modules": [
        "break",
        {
            "type": "os",
            "key": "OS",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        {
            "type": "kernel",
            "key": " ├   KER ",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        {
            "type": "packages",
            "key": " ├   PAK ",
            "format": "{all}",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        {
            "type": "title",
            "key": " └   USR ",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        "break",
        {
            "type": "wm",
            "key": "WM",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "de",
            "key": " ├ 󱈹  DES ",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "shell",
            "key": " ├   SHE ",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "terminal",
            "key": " ├   TER ",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "terminalfont",
            "key": " └   TFO ",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        "break",
        {
            "type": "host",
            "key": "PC",
            "keyColor": "{{colors.secondary_fixed.default.hex}}"
        },
        {
            "type": "cpu",
            "key": " ├   CPU ",
            "keyColor": "{{colors.secondary_fixed.default.hex}}"
        },
        {
            "type": "memory",
            "key": " ├   MEM ",
            "keyColor": "{{colors.secondary_fixed.default.hex}}"
        },
        {
            "type": "gpu",
            "key": " ├ 󰢮  GPU ",
            "format": "{1} {2}",
            "keyColor": "{{colors.secondary_fixed.default.hex}}"
        },
        {
            "type": "disk",
            "key": " ├ 󰋊  DIS ",
            "keyColor": "{{colors.secondary_fixed.default.hex}}"
        },
        {
            "type": "display",
            "key": " └   MON ",
            "format": "{name} {width}x{height}@{refresh-rate} ",
            "keyColor": "{{colors.secondary_fixed.default.hex}}"
        },
        "break",
        // ✅ 已修改：使用全新主题色，随主题变化且不重复
        {
            "type": "uptime",
            "key": "ST",
            "keyColor": "{{colors.tertiary_fixed.default.hex}}"
        },
        {
            "type": "battery",
            "key": " ├   BAT ",
            "keyColor": "{{colors.tertiary_fixed.default.hex}}"
        },
        {
            "type": "swap",
            "key": " └ 󰣂  SWP ",
            "keyColor": "{{colors.tertiary_fixed.default.hex}}"
        },
        "break",
        "colors"
    ]
}
