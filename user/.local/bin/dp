#!/usr/bin/env bash
set -euo pipefail

MAX_ATTEMPTS=100
KEEP_FILES=0
DIFF_FLAGS="-u"
USE_O3=1

DATA_FILE="data.txt"
ANS_FILE="ans.txt"
TEST_FILE="test.txt"
DIFF_CASE_FILE="diff_case.txt"

if [ -f "$DIFF_CASE_FILE" ]; then
    rm "$DIFF_CASE_FILE"
fi

usage() {
    echo "Usage: $0 [options]"
    echo "  -n, --max-attempts <number>  Set maximum test attempts (default: $MAX_ATTEMPTS)"
    echo "  -k, --keep-files             Keep diff_case.txt when counterexample found (default: delete)"
    echo "  -d, --diff-flags <flags>     Diff flags like -bB to ignore spaces (default: '$DIFF_FLAGS')"
    echo "      --no-o3                  Disable O3 optimization (use no optimization for compilation)"
    echo "  -h, --help                   Show this help message"
    exit 0
}

replace_spaces_with_dots() {
    local input_file="$1"
    sed -e 's/ /./g' "$input_file"
}

create_diff_case_file() {
    local attempt=$1
    local diff_file="$DIFF_CASE_FILE"

    >"$diff_file"

    echo "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ" >>"$diff_file"
    echo "в”Ӯ        оқӨ  Counterexample Found - Attempt $attempt            в”Ӯ" >>"$diff_file"
    echo "в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө" >>"$diff_file"
    echo "в”Ӯ Time: $(date)                 в”Ӯ"
    echo "в”Ӯ Config: Max attempts=$MAX_ATTEMPTS, diff flags='$DIFF_FLAGS'             в”Ӯ" >>"$diff_file"
    echo "в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" >>"$diff_file"
    echo "" >>"$diff_file"

    echo "п‘Һ Test Data ($DATA_FILE):" >>"$diff_file"
    echo "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" >>"$diff_file"
    cat $DATA_FILE >>$diff_file
    echo "" >>"$diff_file"

    echo "п”ұ Expected Output ($ANS_FILE) [spaces as '.']:" >>"$diff_file"
    echo "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" >>"$diff_file"
    replace_spaces_with_dots $ANS_FILE >>$diff_file
    echo "" >>"$diff_file"

    echo "п‘і Your Output ($TEST_FILE) [spaces as '.']:" >>"$diff_file"
    echo "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" >>"$diff_file"
    replace_spaces_with_dots $TEST_FILE >>$diff_file
    echo "" >>"$diff_file"

    echo "пң¬ Diff Output (diff $DIFF_FLAGS):" >>"$diff_file"
    echo "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" >>"$diff_file"
    diff $DIFF_FLAGS "$ANS_FILE" "$TEST_FILE" | while IFS= read -r line; do
        echo "$line" >>"$diff_file"
    done
    echo "" >>"$diff_file"

    echo "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ" >>"$diff_file"
    echo "в”Ӯ             п”І    Test Finished                        в”Ӯ" >>"$diff_file"
    echo "в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" >>"$diff_file"
}

cleanup() {
    echo ""
    echo "пҒұ  Interrupt detected, cleaning up..."
    rm -f *.out "$DATA_FILE" "$ANS_FILE" "$TEST_FILE"
    if [[ $KEEP_FILES -eq 0 ]] && [[ -f "$DIFF_CASE_FILE" ]]; then
        rm -f "$DIFF_CASE_FILE"
        echo "пҳі  All temporary files deleted."
    elif [[ -f "$DIFF_CASE_FILE" ]]; then
        echo "пҒҡ  Diff case file preserved: $DIFF_CASE_FILE"
    else
        echo "пҳі  Temporary files deleted."
    fi
    exit 1
}

trap cleanup SIGINT

while getopts "n:kd:h-:" opt; do
    case "$opt" in
    n)
        MAX_ATTEMPTS="$OPTARG"
        ;;
    k)
        KEEP_FILES=1
        ;;
    d)
        DIFF_FLAGS="$OPTARG"
        ;;
    h)
        usage
        ;;
    -)
        case "${OPTARG}" in
        max-attempts)
            MAX_ATTEMPTS="${!OPTIND}"
            OPTIND=$((OPTIND + 1))
            ;;
        keep-files)
            KEEP_FILES=1
            ;;
        diff-flags)
            DIFF_FLAGS="${!OPTIND}"
            OPTIND=$((OPTIND + 1))
            ;;
        no-o3)
            USE_O3=0
            ;;
        help)
            usage
            ;;
        *)
            echo "Error: Unknown long option '--${OPTARG}'" >&2
            usage
            ;;
        esac
        ;;
    \?)
        echo "Error: Unknown option '-$OPTARG'" >&2
        usage
        ;;
    :)
        echo "Error: Option '-$OPTARG' requires an argument" >&2
        usage
        ;;
    esac
done
shift $((OPTIND - 1))

# зЎ®е®ҡзј–иҜ‘дјҳеҢ–еҸӮж•°
if [[ $USE_O3 -eq 1 ]]; then
    OPT_FLAGS="-O3"
else
    OPT_FLAGS=""
fi

echo "пӮӯ  Compiling programs with flags: g++ -std=c++17 $OPT_FLAGS..."
if ! g++ -std=c++17 $OPT_FLAGS ans.cpp -o ans.out; then
    echo "п‘§  Compilation failed: ans.cpp"
    exit 1
fi
if ! g++ -std=c++17 $OPT_FLAGS test.cpp -o test.out; then
    echo "п‘§  Compilation failed: test.cpp"
    exit 1
fi
if ! g++ -std=c++17 $OPT_FLAGS data.cpp -o data.out; then
    echo "п‘§  Compilation failed: data.cpp"
    exit 1
fi
echo "пҳі  All programs compiled successfully!"
echo "--------------------"

echo "пҡҖ  Starting automated testing..."
echo "п ө  Press Ctrl+C to interrupt and cleanup."
echo "п ө  Config: Max attempts=$MAX_ATTEMPTS, Keep files=$([ $KEEP_FILES -eq 1 ] && echo "Yes" || echo "No"), Diff flags='$DIFF_FLAGS', Optimization=$OPT_FLAGS"
echo "--------------------"

count=0
found_counterexample=0

while ((count < MAX_ATTEMPTS)); do
    ((++count))

    echo "Running test attempt $count..."

    echo "  - Generating test data..."
    if ! ./data.out >"$DATA_FILE"; then
        echo "п‘§  Data generator crashed!"
        exit 1
    fi

    echo "  - Running reference program (ans.out)..."
    if ! ./ans.out <"$DATA_FILE" >"$ANS_FILE"; then
        echo "п‘§  Reference program crashed!"
        exit 1
    fi

    echo "  - Running your program (test.out)..."
    if ! ./test.out <"$DATA_FILE" >"$TEST_FILE"; then
        echo "п‘§  Your program crashed!"
        exit 1
    fi

    echo "  - Comparing outputs (using: $DIFF_FLAGS)..."
    if ! eval "diff $DIFF_FLAGS \"$ANS_FILE\" \"$TEST_FILE\"" >/dev/null; then
        found_counterexample=1
        echo "--------------------"
        echo "п‘§  Counterexample found! On attempt $count."

        create_diff_case_file "$count" || true
        echo "пңҳ  Diff case saved to: $DIFF_CASE_FILE"
        echo ""
        echo "пң¬ Diff preview:"
        echo "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
        eval "diff $DIFF_FLAGS \"$ANS_FILE\" \"$TEST_FILE\" | head -20" || true
        if eval "diff $DIFF_FLAGS \"$ANS_FILE\" \"$TEST_FILE\" | head -21 | tail -1" >/dev/null 2>&1; then
            echo "   ... (full diff in $DIFF_CASE_FILE)"
        fi
        echo "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"

        rm -f *.out "$DATA_FILE" "$ANS_FILE" "$TEST_FILE"
        break
    else
        echo "  - Attempt $count: Outputs match."
    fi

    echo "--------------------"
done

if ((!found_counterexample)); then
    rm -f *.out "$DATA_FILE" "$ANS_FILE" "$TEST_FILE"
fi

if ((found_counterexample)); then
    echo ""
    if [[ $KEEP_FILES -eq 1 ]]; then
        echo "пҳі  Counterexample analysis complete. Diff report: $DIFF_CASE_FILE"
    else
        echo "пҒҡ  Counterexample found. Diff report will be deleted at exit."
        echo "   Use -k option to preserve the diff report file."
    fi
elif ((count >= MAX_ATTEMPTS)); then
    echo "пҳі  All $MAX_ATTEMPTS attempts completed. No counterexamples found. Test passed!"
fi

if [[ $KEEP_FILES -eq 0 ]] && [[ -f "$DIFF_CASE_FILE" ]]; then
    rm -f "$DIFF_CASE_FILE"
    echo "пҳі  All temporary files cleaned up."
elif [[ -f "$DIFF_CASE_FILE" ]]; then
    echo "пңҳ  Diff report preserved: $DIFF_CASE_FILE"
    clear
    cat "$DIFF_CASE_FILE"
fi

echo "п«   Script finished."
